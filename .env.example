# LangGraph 电商客服 Agent Harness V4-lite
# 环境变量示例文件
# 复制此文件为 .env 并填入实际值

# LLM Provider 配置（默认 mock，不调用真实 API）
# LLM_PROVIDER=mock
# LLM_ENABLE_REPLY_POLISH=false
# LLM_TIMEOUT_SECONDS=15

# DeepSeek API（仅在 LLM_PROVIDER=deepseek 时需要）
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# LLM RAG answer（默认关闭）
# LLM_ENABLE_RAG_ANSWER=false

# LLM Semantic Parser（默认关闭，用于意图理解增强）
# LLM_ENABLE_SEMANTIC_PARSER=false

# RAG Provider（默认 tfidf，可选 chroma）
# RAG_PROVIDER=tfidf
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
